{
  "agents": {
    "coder": {
      "name": "coder",
      "role": "Software development assistant",
      "model": "claude-sonnet-4-5",
      "thinking": 4096,
      "tools": ["shell", "read_file", "write_file", "edit_file", "list_files"],
      "context": {
        "tags": ["code", "high-priority"],
        "budget": 50000,
        "inherit_parent": false
      }
    },
    "security": {
      "name": "security",
      "role": "Security gatekeeper - reviews and approves/denies operations",
      "model": "claude-sonnet-4-5",
      "thinking": 2048,
      "tools": [],
      "context": {
        "tags": ["security", "always"],
        "budget": 20000,
        "inherit_parent": false
      },
      "hooks": {
        "hooks": ["on_tool_call"],
        "gatekeeper_for": ["coder", "researcher"]
      }
    },
    "cost-monitor": {
      "name": "cost-monitor",
      "role": "Cost monitoring agent - tracks token usage and enforces budget limits",
      "model": "claude-haiku-4",
      "thinking": 0,
      "tools": [],
      "context": {
        "tags": ["metrics"],
        "budget": 5000,
        "inherit_parent": false
      },
      "hooks": {
        "hooks": ["on_after_response", "on_session_end"],
        "schedule": {
          "interval": "5m"
        }
      }
    },
    "logger": {
      "name": "logger",
      "role": "Audit logger - logs all operations for compliance",
      "model": "claude-haiku-4",
      "thinking": 0,
      "tools": ["write_file"],
      "context": {
        "tags": ["audit"],
        "budget": 5000,
        "inherit_parent": false
      },
      "hooks": {
        "hooks": [
          "on_session_start",
          "on_tool_call",
          "on_tool_result",
          "on_before_spawn",
          "on_after_spawn",
          "on_session_end"
        ]
      }
    },
    "researcher": {
      "name": "researcher",
      "role": "Research assistant with web search capabilities",
      "model": "claude-sonnet-4-5",
      "thinking": 2048,
      "tools": ["shell", "read_file", "write_file"],
      "context": {
        "tags": ["research", "high-priority"],
        "budget": 40000,
        "inherit_parent": false
      },
      "hooks": {
        "hooks": ["on_before_request"]
      }
    }
  }
}
